{
  "name": "dossier-immo-workspace",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "pnpm --filter @dossier-immo/web dev",
    "runtime:check": "node -e \"const expected = 'v24.18.0'; if (process.version !== expected) { console.error('Runtime Node attendu : ' + expected + ', obtenu : ' + process.version); process.exit(1); } console.log('Runtime Node projet : ' + process.version);\"",
    "build": "pnpm typecheck && pnpm test:unit && pnpm --filter @dossier-immo/web build",
    "typecheck": "tsc -b",
    "test": "pnpm test:unit && pnpm test:dev && pnpm test:e2e",
    "test:dev": "node tools/check-dev-server.mjs",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && node tools/run-e2e.mjs",
    "test:e2e:update": "pnpm build && node tools/run-e2e.mjs --update-snapshots",
    "contracts:export": "vite-node tools/export-contracts.ts",
    "validate:file": "vite-node tools/validate-dossier.ts",
    "generate:pdf": "vite-node tools/generate-pdf.ts",
    "check:layout": "vite-node tools/check-document-layout.ts",
    "deps:audit": "pnpm audit --audit-level=moderate",
    "deps:tree": "pnpm list --depth Infinity",
    "deps:outdated": "pnpm outdated --long",
    "deps:sbom": "pnpm sbom --format cyclonedx",
    "deps:policy": "node tools/check-dependency-policy.mjs",
    "deps:trust-exclusions": "node tools/check-dependency-policy.mjs --probe"
  },
  "engines": {
    "node": ">=22.13"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "error"
    }
  },
  "devDependencies": {
    "@dossier-immo/calculations": "workspace:*",
    "@dossier-immo/document": "workspace:*",
    "@dossier-immo/domain": "workspace:*",
    "@dossier-immo/fixtures": "workspace:*",
    "@dossier-immo/schema": "workspace:*",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.13.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fast-check": "^4.3.0",
    "pdfjs-dist": "^5.4.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.2.0"
  }
}
